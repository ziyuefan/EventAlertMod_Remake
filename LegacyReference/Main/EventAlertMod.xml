	<Frame 	name="EA_Main_Frame" 
			parent="UIParent" 
			toplevel="true" 
			frameStrata="LOW" 
			enableKeyboard="true">
		<Size>
			<AbsDimension x="1" y="1" />
		</Size>
		<Scripts>
			
			<OnLoad>
				 C_AddOns.GetAddOnLocalTable("EventAlertMod"):OnLoad(self) 				
				 <!-- _G.EventAlertMod:OnLoad(self) -->
				self:SetPropagateKeyboardInput(true)				
			</OnLoad>
