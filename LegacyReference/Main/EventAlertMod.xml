			<!-- </OnKeyDown> -->
		</Scripts>
	</Frame>
	
	<Frame 	name="EA_Version_Frame" 
			hidden="true" 
			parent="UIParent" 
			movable="true" 
			frameStrata="DIALOG">	
		 
		<Size>
			<AbsDimension x="400" y="350" />
		</Size>
		<Anchors>
			<Anchor relativepoint="CENTER" 
					point="CENTER" />
		</Anchors>
		
		<Frames>
			<Button name="$parent_Okay" 
					inherits="UIPanelButtonTemplate" 
					text="Okay">
				<Size>
					<AbsDimension x="75" y="21" />
				</Size>
				<Anchors>
					<Anchor relativepoint="BOTTOM" 
							point="CENTER">
						<Offset>
							<AbsDimension x="0" y="25" />
						</Offset>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						PlaySound(SOUNDKIT.GS_TITLE_OPTION_OK)
						<!-- HideUIPanel(EA_Version_Frame)						 -->
					</OnClick>
				</Scripts>
			</Button>
		</Frames>
		<Layers>
			<Layer>
				<Texture 	name="$parent_Header" 
							file="Interface/DialogFrame/UI-DialogBox-Header">
					<Size>
						<AbsDimension x="400" y="64" />
					</Size>
					<Anchors>
						<Anchor point="TOP">
							<Offset>
								<AbsDimension x="0" y="24" />
							</Offset>
						</Anchor>
					</Anchors>
				</Texture>
				<FontString name="$parent_HeaderText" 
							inherits="GameFontNormal" 
							text="New EventAlertMod Version!">
					<Anchors>
						<Anchor point="TOP" 
								relativeTo="$parent_Header">
							<Offset>
								<AbsDimension x="0" y="-14" />
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
		
			<OnMouseDown>
				if button == "LeftButton" then
					self:StartMoving()
				end
			</OnMouseDown>
			<OnMouseUp>
				if button == "LeftButton" then
					self:StopMovingOrSizing()
				end
			</OnMouseUp>
		</Scripts>
	</Frame>
	<FontString name="FontString1" 
				inherits="GameFontNormal" 
				text="FontString1">
	
		<Size>
